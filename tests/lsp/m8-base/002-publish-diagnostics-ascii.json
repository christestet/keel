{
  "schema": "keel-lsp-transcript/v1",
  "case": "002-publish-diagnostics-ascii",
  "description": "A semicolon parse diagnostic is published with a stable K-code and 0-based LSP range for ASCII source.",
  "messages": [
    {
      "direction": "client",
      "kind": "notification",
      "message": {
        "jsonrpc": "2.0",
        "method": "textDocument/didOpen",
        "params": {
          "textDocument": {
            "uri": "file:///workspace/main.keel",
            "languageId": "keel",
            "version": 1,
            "text": "fn main() -> Unit {\n    print(\"hi\");\n}\n"
          }
        }
      }
    },
    {
      "direction": "server",
      "kind": "notification",
      "expect": {
        "jsonrpc": "2.0",
        "method": "textDocument/publishDiagnostics",
        "params": {
          "uri": "file:///workspace/main.keel",
          "diagnostics": [
            {
              "range": {
                "start": {
                  "line": 1,
                  "character": 15
                },
                "end": {
                  "line": 1,
                  "character": 16
                }
              },
              "severity": 1,
              "code": "K0102",
              "source": "keelc",
              "message": "Keel uses newline-based statement termination; semicolons are not allowed"
            }
          ]
        }
      }
    }
  ]
}

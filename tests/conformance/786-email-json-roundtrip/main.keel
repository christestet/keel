use std.json

fn quote() -> Char { '"' }

fn main() {
    let encoded = json.write(
        json.parse<Email>("{quote()}ada.lovelace+keel@example.com{quote()}") catch err {
            other => return print("parse error"),
        },
    ) catch err {
        other => return print("write error"),
    }
    print(encoded)
}

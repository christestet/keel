use std.json

fn quote() -> Char { '"' }

fn main() {
    let email = json.parse<Email>("{quote()}ada.lovelace+keel@example.com{quote()}") catch err {
        other => return print("parse error"),
    }
    let encoded = json.write(email) catch err {
        other => return print("write error"),
    }
    print(encoded)
}

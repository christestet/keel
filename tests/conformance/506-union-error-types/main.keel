enum ParseError {
    BadDigit,
}

enum RangeError {
    TooBig,
}

fn parse_one(s: String) -> Result<Int, ParseError> {
    if s == "1" { Ok(1) } else { Err(BadDigit) }
}

fn bounded(n: Int) -> Result<Int, RangeError> {
    if n < 10 { Ok(n) } else { Err(TooBig) }
}

fn pipeline(s: String) -> Result<Int, ParseError | RangeError> {
    let n = parse_one(s)?
    let b = bounded(n)?
    Ok(b + 100)
}

fn main() {
    match pipeline("1") {
        Ok(v)  => print("ok: {v}"),
        Err(_) => print("failed"),
    }
    match pipeline("x") {
        Ok(v)  => print("ok: {v}"),
        Err(_) => print("failed"),
    }
}

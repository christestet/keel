enum DbError {
    NotFound(id: Int),
    Timeout,
}

fn get_name(id: Int) -> Result<String, DbError> {
    if id == 1 { Ok("ada") } else { Err(Timeout) }
}

fn lookup(id: Int) -> Result<String, DbError> {
    let name = get_name(id) catch err {
        NotFound(_) => return Ok("missing"),
        Timeout     => return Ok("slow"),
    }
    Ok("user: {name}")
}

fn main() {
    match lookup(1) {
        Ok(v)  => print(v),
        Err(_) => print("error"),
    }
    match lookup(2) {
        Ok(v)  => print(v),
        Err(_) => print("error"),
    }
}

interface Stringer {
    fn to_string(self) -> String
}

struct Point {
    x: Int
    y: Int
}

impl Stringer for Point {
    fn to_string(self) -> String {
        "({self.x}, {self.y})"
    }
}

fn show(it: Stringer) -> String {
    it.to_string()
}

fn make_stringer(x: Int, y: Int) -> Stringer {
    Point { x: x, y: y }
}

fn main() {
    let p = Point { x: 5, y: 6 }
    print(show(p))
    print(make_stringer(7, 8).to_string())
}

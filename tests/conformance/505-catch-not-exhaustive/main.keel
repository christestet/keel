enum DbError {
    NotFound(id: Int),
    Timeout,
}

fn get_name(id: Int) -> Result<String, DbError> {
    if id == 1 { Ok("ada") } else { Err(NotFound(id)) }
}

fn lookup(id: Int) -> Result<String, DbError> {
    let name = get_name(id) catch err {
        NotFound(_) => return Ok("guest"),
    }
    Ok(name)
}

fn main() {
    print("unused")
}

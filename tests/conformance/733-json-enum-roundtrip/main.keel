use std.json

enum Status {
    Active,
    Suspended(reason: String),
}

fn main() {
    let encoded = json.write(Suspended("maintenance"))
    let decoded = json.parse<Status>(encoded) catch err {
        other => return print("parse error"),
    }
    match decoded {
        Active => print("active"),
        Suspended(reason) => print("{encoded}: {reason}"),
    }
}
